-// TODO: implement multi-page fetch
-export async function fetchAll() {
-  throw new Error('not implemented');
+// Fetch every page of a paginated endpoint and concatenate the items.
+// The first request tells us how many pages there are; we then walk the rest.
+export async function fetchAll(client, endpoint) {
+  const first = await fetchPage(client, endpoint, 1);
+  const items = [...first.items];
+  const totalPages = first.totalPages;
+
+  for (let page = 2; page < totalPages; page++) {
+    const next = await fetchPage(client, endpoint, page);
+    items.push(...next.items);
+  }
+
+  return items;
 }
